local HM, TH, TD = false, false, nil
local MaxMauTuyChinh = 100
local GB, SP, CC, JumpConnection

task.spawn(function()
    while true do
        local p = game.Players.LocalPlayer
        local c = p.Character
        if c and c:FindFirstChildOfClass("Humanoid") then
            local h = c:FindFirstChildOfClass("Humanoid")
            if h.MaxHealth ~= MaxMauTuyChinh then h.MaxHealth = MaxMauTuyChinh end
            if HM and h.Health > 0 and h.Health < h.MaxHealth then
                h.Health = math.min(h.Health + 2000, h.MaxHealth)
            end
            h.WalkSpeed = TH and 0 or (TD or 16)
        end
        task.wait(0.01)
    end
end)

B1.MouseButton1Click:Connect(function()
    HM = not HM
    B1.BackgroundColor3 = HM and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
    B1.Text = HM and "HỒI MÁU: BẬT" or "HỒI MÁU: TẮT"
end)

B2.MouseButton1Click:Connect(function()
    local h = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if h then h.Health = h.MaxHealth end
end)

B3.MouseButton1Click:Connect(function()
    local c = game.Players.LocalPlayer.Character
    if not c or not c:FindFirstChild("HumanoidRootPart") then return end
    local r, cam, hum = c.HumanoidRootPart, workspace.CurrentCamera, c:FindFirstChildOfClass("Humanoid")
    TH = not TH
    
    B3.BackgroundColor3 = TH and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
    B3.Text = TH and "TÀNG HÌNH: BẬT" or "TÀNG HÌNH: TẮT"
    
    if TH then
        c.Archivable = true
        GB = c:Clone()
        c.Archivable = false
        GB.Parent = workspace
        
        local ghum = GB:FindFirstChildOfClass("Humanoid")
        if ghum then ghum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None end
        
        local gr = GB:FindFirstChild("HumanoidRootPart")
        if gr then gr.Anchored = false end -- Không khóa cứng để bóng có thể rơi tự do
        
        SP = Instance.new("Part", workspace)
        SP.Size, SP.Transparency, SP.Anchored = Vector3.new(6, 1, 6), 1, true
        
        for _, p in pairs(c:GetDescendants()) do
            if p:IsA("BasePart") or p:IsA("Decal") then p.Transparency = 1 end
        end
        
        -- Đồng bộ phím Nhảy (Space) sang cái bóng
        JumpConnection = hum:GetPropertyChangedSignal("Jump"):Connect(function()
            if ghum then ghum.Jump = hum.Jump end
        end)
        
        CC = game:GetService("RunService").RenderStepped:Connect(function()
            if GB and gr and r and SP and hum and ghum then
                local md = hum.MoveDirection
                local sp = TD or 16
                
                -- Di chuyển bóng mượt mà dưới đất
                gr.CFrame = gr.CFrame + (md * (sp * game:GetService("RunService").RenderStepped:Wait()))
                if md.Magnitude > 0 then gr.CFrame = CFrame.new(gr.Position, gr.Position + md) end
                
                -- Khóa nhân vật thật (đang tàng hình) bám sát theo vị trí bóng dưới đất
                r.CFrame = gr.CFrame
                SP.CFrame = r.CFrame - Vector3.new(0, 3, 0)
                cam.CameraSubject = ghum
            end
        end)
    else
        if CC then CC:Disconnect() end
        if JumpConnection then JumpConnection:Disconnect() end
        if GB and r then 
            local gr = GB:FindFirstChild("HumanoidRootPart")
            if gr then r.CFrame = gr.CFrame end
            GB:Destroy() GB = nil 
        end
        if SP then SP:Destroy() end
        task.wait(0.05)
        cam.CameraSubject = hum
        for _, p in pairs(c:GetDescendants()) do
            if (p:IsA("BasePart") and p.Name ~= "HumanoidRootPart") or p:IsA("Decal") then p.Transparency = 0 end
        end
    end
end)

