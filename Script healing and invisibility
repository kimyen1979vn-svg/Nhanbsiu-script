B1.MouseButton1Click:Connect(function() HM = not HM; B1.BackgroundColor3 = HM and Color3.fromRGB(50,200,50) or Color3.fromRGB(45, 20, 50); B1.Text = HM and "HỒI MÁU: BẬT" or "HỒI MÁU: TẮT" end)
B2.MouseButton1Click:Connect(function() local h = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid") if h then h.Health = h.MaxHealth end end)

B3.MouseButton1Click:Connect(function()
    local c = game.Players.LocalPlayer.Character; if not c or not c:FindFirstChild("HumanoidRootPart") then return end
    local r, cam, hum = c.HumanoidRootPart, workspace.CurrentCamera, c:FindFirstChildOfClass("Humanoid")
    TH = not TH; B3.BackgroundColor3 = TH and Color3.fromRGB(50,200,50) or Color3.fromRGB(45, 20, 50); B3.Text = TH and "TÀNG HÌNH: BẬT" or "TÀNG HÌNH: TẮT"
    if TH then
        FakePos = r.CFrame
        SkyPlatform = Instance.new("Part", workspace)
        SkyPlatform.Size = Vector3.new(15, 1, 15); SkyPlatform.CFrame = FakePos + Vector3.new(0, 200, 0); SkyPlatform.Transparency = 1; SkyPlatform.Anchored = true; SkyPlatform.CanCollide = true
        WhiteBlock = Instance.new("Part", workspace); WhiteBlock.Size = Vector3.new(2, 4, 2); WhiteBlock.Color = Color3.fromRGB(0, 191, 255); WhiteBlock.Material = Enum.Material.Neon; WhiteBlock.Transparency = 0.5; WhiteBlock.CanCollide = false; WhiteBlock.Anchored = true
        for _, p in pairs(c:GetDescendants()) do if p:IsA("BasePart") or p:IsA("Decal") then p.Transparency = 1 end end
        r.CFrame = SkyPlatform.CFrame + Vector3.new(0, 3, 0)
        CC = game:GetService("RunService").RenderStepped:Connect(function(dt)
            if TH and r and hum and WhiteBlock then
                local md = hum.MoveDirection; FakePos = FakePos + (md * (TD * dt)); WhiteBlock.CFrame = FakePos
                r.CFrame = SkyPlatform.CFrame + Vector3.new(0, 3, 0); r.Velocity = Vector3.new(0,0,0); cam.CameraSubject = WhiteBlock
            end
        end)
    else
        if CC then CC:Disconnect() end
        if WhiteBlock and r then r.CFrame = WhiteBlock.CFrame + Vector3.new(0, 3, 0) end
        if WhiteBlock then WhiteBlock:Destroy() WhiteBlock = nil end; if SkyPlatform then SkyPlatform:Destroy() SkyPlatform = nil end
        task.wait(0.05); cam.CameraSubject = hum
        for _, p in pairs(c:GetDescendants()) do if (p:IsA("BasePart") and p.Name ~= "HumanoidRootPart") or p:IsA("Decal") then p.Transparency = 0 end end
    end
end)

BE.MouseButton1Click:Connect(function()
    EspActive = not EspActive; BE.BackgroundColor3 = EspActive and Color3.fromRGB(50,200,50) or Color3.fromRGB(45, 20, 50); BE.Text = EspActive and "ESP PLAYER: BẬT" or "ESP PLAYER: TẮT"
    if EspActive then 
        for _, plr in pairs(game.Players:GetPlayers()) do
            if plr ~= game.Players.LocalPlayer then
                local B = Instance.new("BillboardGui", game.CoreGui); B.Size = UDim2.new(0,100,0,50); B.AlwaysOnTop = true
                local T = Instance.new("TextLabel", B); T.Size = UDim2.new(1,0,1,0); T.BackgroundTransparency = 1; T.TextColor3 = Color3.new(0,1,0)
                game:GetService("RunService").RenderStepped:Connect(function()
                    if EspActive and plr.Character and plr.Character:FindFirstChild("Head") then B.Adornee = plr.Character.Head; T.Text = "@"..plr.Name.." HP:"..math.floor(plr.Character.Humanoid.Health) else B.Adornee = nil end
                end)
            end
        end
    end
end)

BS.MouseButton1Click:Connect(function() 
    local id = SI_Server.Text ~= "" and SI_Server.Text or game.PlaceId
    game:GetService("TeleportService"):Teleport(id, game.Players.LocalPlayer) 
end)

game:GetService("RunService").RenderStepped:Connect(function()
    UIGradient.Rotation = (UIGradient.Rotation + 1) % 360
    local char = game.Players.LocalPlayer.Character
    local h = char and char:FindFirstChildOfClass("Humanoid")
    if h then
        h.MaxHealth = MaxH
        if HM and h.Health < h.MaxHealth then h.Health = h.Health + 1 end
        if not FlyActive then h.WalkSpeed = TH and 0 or TD end
        -- Chỉnh Size nhân vật
        if char:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.Size = v.Size * CharSize end
            end
        end
    end
end)

BF.MouseButton1Click:Connect(function()
    FlyActive = not FlyActive; BF.BackgroundColor3 = FlyActive and Color3.fromRGB(50,200,50) or Color3.fromRGB(45, 20, 50); BF.Text = FlyActive and "FLY: BẬT" or "FLY: TẮT"
    local r = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if FlyActive and r then
        BG = Instance.new("BodyGyro", r); BG.MaxTorque = Vector3.new(1,1,1)*9e9; BV = Instance.new("BodyVelocity", r); BV.MaxForce = Vector3.new(1,1,1)*9e9
        FC = game:GetService("RunService").RenderStepped:Connect(function() BV.Velocity = (workspace.CurrentCamera.CFrame.LookVector * (game.Players.LocalPlayer.Character.Humanoid.MoveDirection.Z * -FlySpeed)) + (workspace.CurrentCamera.CFrame.RightVector * (game.Players.LocalPlayer.Character.Humanoid.MoveDirection.X * FlySpeed)) end)
    else if FC then FC:Disconnect() end; if BG then BG:Destroy() end; if BV then BV:Destroy() end end
end)

